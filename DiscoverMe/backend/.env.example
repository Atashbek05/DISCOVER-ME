# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/discover_me

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars_different

JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Use * to allow all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=debug
